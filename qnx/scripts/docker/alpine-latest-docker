ARG CODE_VERSION=latest
FROM alpine:${CODE_VERSION}
LABEL MAINTAINER="Davide Cunial <dcunial@proton.me>"

RUN apk update                                                          \
    && apk add clang clang-extra-tools compiler-rt lld libc++-dev       \
    llvm llvm-linker-tools llvm-libunwind-dev musl-dev cmake samurai    \
    linux-headers libxml2-dev

RUN mkdir /source
RUN mkdir /build
WORKDIR /build
CMD [ "sh" ]
